---
import SectionMarkdownPage from "../../components/SectionMarkdownPage.astro";
import { getSectionPagesForSection } from "../../lib/sectionPages";
import type { SectionPageEntry } from "../../lib/sectionPages";

export async function getStaticPaths() {
  const pages = await getSectionPagesForSection("contact");

  return pages.map(({ slug, entry }) => ({
    params: { slug },
    props: { entry }
  }));
}

interface Props {
  entry: SectionPageEntry;
}

const { entry } = Astro.props;
---

<SectionMarkdownPage entry={entry} />
