---
import { render } from "astro:content";
import type { SectionPageEntry } from "../lib/sectionPages";
import SectionPageTemplate from "./SectionPageTemplate.astro";

interface Props {
  entry: SectionPageEntry;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const hasContent = (entry.body ?? "").trim().length > 0;
---

<SectionPageTemplate page={entry.data}>
  {hasContent && (
    <div class="prose-content">
      <Content />
    </div>
  )}
</SectionPageTemplate>
